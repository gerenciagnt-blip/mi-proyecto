// Sistema PILA — esquema base
// Multi-tenant por Sucursal (cada aliado = una sucursal).
// Empresas son globales (admin-gestionadas), accesibles por usuarios vía UsuarioEmpresa.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Roles del sistema ---
// Niveles base — cada usuario tiene uno. Para refinar permisos dentro
// de un nivel, se le asigna además un `RolCustom` con su propia matriz
// de permisos.
enum Role {
  ADMIN         // staff plataforma — ve todo, sin sucursal
  SOPORTE       // staff plataforma — mismos permisos base que ADMIN pero con matriz configurable
  ALIADO_OWNER  // dueño del aliado — ve toda su sucursal
  ALIADO_USER   // [DEPRECADO] usar ALIADO_OWNER + rolCustom. Se mantiene por retrocompatibilidad.
}

enum TipoPersona {
  NATURAL
  JURIDICA
}

enum TipoDocumento {
  CC
  CE
  NIT
  PAS
  TI
  RC
  NIP
}

enum NivelRiesgo {
  I
  II
  III
  IV
  V
}

enum TipoEntidadSgss {
  EPS
  AFP
  ARL
  CCF
}

enum Genero {
  M
  F
  O // Otro
}

enum EstadoAfiliacion {
  ACTIVA
  INACTIVA
}

enum Regimen {
  ORDINARIO
  RESOLUCION
}

// Modalidad de afiliación — discrimina el flujo de independientes vs dependientes.
// Se guarda tanto en el catálogo (TipoCotizante) como en la afiliación para
// filtrado rápido y reglas de validación específicas por rama.
enum Modalidad {
  DEPENDIENTE
  INDEPENDIENTE
}

// Forma de pago — aplica sólo a INDEPENDIENTE.
// VIGENTE  = paga por adelantado (cubre el mismo mes en que cotiza)
// VENCIDO  = paga el mes siguiente (cubre el mes anterior)
enum FormaPago {
  VIGENTE
  VENCIDO
}

// Bitácora transversal — registra cambios sobre entidades del sistema.
// Patrón simple: guardamos antes/después como JSON para auditoría.
model AuditLog {
  id         String   @id @default(cuid())
  entidad    String // ej. "Afiliacion"
  entidadId  String
  accion     String // "CREAR" | "EDITAR" | "ELIMINAR" | "TOGGLE"
  userId     String?
  userName   String?
  descripcion String?
  cambios    Json? // { antes: {...}, despues: {...}, campos: [...] }
  createdAt  DateTime @default(now())

  @@index([entidad, entidadId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// Bitácora de intentos de login — usada por el rate-limit de 3 fallos
// en 10 min. Se consulta filtrando por email y createdAt > ahora-10min.
// `success` permite diferenciar intentos exitosos y correctos (para
// limpiar contador) de los fallidos (que suman al bloqueo).
model LoginAttempt {
  id         String   @id @default(cuid())
  email      String // normalizado a lowercase
  ip         String?
  userAgent  String?
  success    Boolean  @default(false)
  motivo     String? // "password_wrong" | "user_inactive" | "unknown_email" | "rate_limited"
  createdAt  DateTime @default(now())

  @@index([email, createdAt])
  @@index([createdAt])
  @@map("login_attempts")
}

// Permisos granulares: qué puede hacer cada rol en cada módulo.
// Presencia en la tabla = permitido. Ausencia = denegado.
// ADMIN implícitamente tiene todos los permisos (se saltea esta tabla).
model Permiso {
  role   Role
  modulo String // clave del módulo ej. "config.sucursales"
  accion String // "VER" | "CREAR" | "EDITAR" | "ELIMINAR"

  @@id([role, modulo, accion])
  @@map("permisos")
}

// Roles personalizados creados por el admin — variaciones con
// permisos específicos sobre un rol base (ALIADO_OWNER o SOPORTE).
// Ejemplos: "Operaciones", "Facturación", "Cartera" heredando de
// ALIADO_OWNER con permisos restringidos.
model RolCustom {
  id          String   @id @default(cuid())
  nombre      String   @unique
  descripcion String?
  basedOn     Role // ALIADO_OWNER o SOPORTE (ADMIN no se personaliza)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permisos PermisoCustom[]
  users    User[]

  @@map("roles_custom")
}

model PermisoCustom {
  rolCustomId String
  modulo      String
  accion      String

  rolCustom RolCustom @relation(fields: [rolCustomId], references: [id], onDelete: Cascade)

  @@id([rolCustomId, modulo, accion])
  @@map("permisos_custom")
}

// --- Sucursal = tenant (cada aliado tiene la suya) ---
model Sucursal {
  id               String   @id @default(cuid())
  codigo           String   @unique // ej. "ALI-001"
  nombre           String
  active           Boolean  @default(true)
  bloqueadaPorMora Boolean  @default(false) // si true, el aliado solo puede ver/pagar su CxC
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users              User[]
  cuentasCobro       CuentaCobro[]
  comprobanteFormato ComprobanteFormato?
  mediosPago         MedioPago[]
  asesoresComerciales AsesorComercial[]
  serviciosAdicionales ServicioAdicional[]
  cotizantes         Cotizante[]
  planillas          Planilla[]
  carterasAsignadas  CarteraDetallado[]

  @@map("sucursales")
}

// --- Usuario del sistema ---
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role
  sucursalId   String? // NULL solo para ADMIN/SOPORTE
  /**
   * Rol custom opcional. Si está seteado, los permisos efectivos del
   * usuario son los definidos en PermisoCustom para ese rol. Si es NULL,
   * el usuario usa la matriz Permiso del rol base.
   * Permite crear perfiles granulares (Operaciones, Facturación, etc.)
   * heredando de ALIADO_OWNER o SOPORTE.
   */
  rolCustomId  String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sucursal            Sucursal?        @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  rolCustom           RolCustom?       @relation(fields: [rolCustomId], references: [id], onDelete: SetNull)
  empresas            UsuarioEmpresa[]
  comprobantesCreados Comprobante[]    @relation("ComprobantesCreados")
  planillasCreadas    Planilla[]       @relation("PlanillasCreadas")
  carterasCreadas     CarteraConsolidado[] @relation("CarterasCreadas")
  carterasGestiones   CarteraGestion[]     @relation("CarterasGestionesUser")

  @@index([sucursalId])
  @@index([rolCustomId])
  @@map("users")
}

// --- Empresa cliente — global, administrada solo por ADMIN ---
model Empresa {
  id        String   @id @default(cuid())
  nit       String   @unique // único globalmente
  nombre    String // razón social

  // Identificación adicional (Fase 1.5.1 — nullable para migración no destructiva)
  dv              String?
  nombreComercial String?
  tipoPersona     TipoPersona?

  // Representante legal
  repLegalTipoDoc   TipoDocumento?
  repLegalNumeroDoc String?
  repLegalNombre    String?

  // Ubicación y contacto
  direccion      String?
  ciudad         String? // legado - texto libre (queda sincronizado con municipio.nombre si aplica)
  departamento   String? // legado - texto libre
  departamentoId String? // nuevo - FK a DIVIPOLA
  municipioId    String? // nuevo - FK a DIVIPOLA
  telefono       String?
  email          String?

  // PILA
  ciiuPrincipal    String?
  arlId            String?
  exoneraLey1607   Boolean @default(false) // exoneración de aportes Ley 1607 de 2012
  arl              EntidadSgss?  @relation("EmpresaArl", fields: [arlId], references: [id], onDelete: SetNull)
  departamentoRef  Departamento? @relation("EmpresaDepto", fields: [departamentoId], references: [id], onDelete: SetNull)
  municipioRef     Municipio?    @relation("EmpresaMuni", fields: [municipioId], references: [id], onDelete: SetNull)

  // Relaciones de "permitidos" (Fase 1.5.3)
  nivelesPermitidos   EmpresaNivelRiesgo[]
  actividadesPermitidas EmpresaActividad[]
  tiposPermitidos     EmpresaTipoCotizante[]
  subtiposPermitidos  EmpresaSubtipoCotizante[]

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accesos      UsuarioEmpresa[]
  afiliaciones Afiliacion[]
  planillas    Planilla[]
  carterasConsolidado CarteraConsolidado[]

  @@index([arlId])
  @@index([departamentoId])
  @@index([municipioId])
  @@map("empresas")
}

// Empresa ↔ niveles de riesgo ARL permitidos (I, II, III, IV, V)
model EmpresaNivelRiesgo {
  empresaId String
  nivel     NivelRiesgo
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@id([empresaId, nivel])
  @@map("empresa_nivel_riesgo")
}

// Empresa ↔ actividades económicas adicionales permitidas
model EmpresaActividad {
  empresaId            String
  actividadEconomicaId String
  empresa              Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  actividad            ActividadEconomica @relation(fields: [actividadEconomicaId], references: [id], onDelete: Cascade)

  @@id([empresaId, actividadEconomicaId])
  @@map("empresa_actividad")
}

// Empresa ↔ tipos de cotizante permitidos
model EmpresaTipoCotizante {
  empresaId       String
  tipoCotizanteId String
  empresa         Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  tipoCotizante   TipoCotizante @relation(fields: [tipoCotizanteId], references: [id], onDelete: Cascade)

  @@id([empresaId, tipoCotizanteId])
  @@map("empresa_tipo_cotizante")
}

// Empresa ↔ subtipos de cotizante permitidos
model EmpresaSubtipoCotizante {
  empresaId String
  subtipoId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  subtipo   Subtipo @relation(fields: [subtipoId], references: [id], onDelete: Cascade)

  @@id([empresaId, subtipoId])
  @@map("empresa_subtipo_cotizante")
}

// --- Permiso granular: qué usuario puede ver qué empresa ---
model UsuarioEmpresa {
  userId    String
  empresaId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@id([userId, empresaId])
  @@map("usuarios_empresas")
}

// --- Catálogos ---

// Entidades SGSS unificadas (EPS, AFP, ARL, CCF)
// Fase 1.6.1 — reemplaza el modelo Arl individual por una tabla tipada.
model EntidadSgss {
  id             String          @id @default(cuid())
  tipo           TipoEntidadSgss
  codigo         String
  nombre         String
  codigoMinSalud String?
  nit            String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // Relaciones — empresas cuyo ARL actual es esta entidad
  empresasComoArl     Empresa[]    @relation("EmpresaArl")
  afiliacionesComoEps Afiliacion[] @relation("AfilEps")
  afiliacionesComoAfp Afiliacion[] @relation("AfilAfp")
  afiliacionesComoArl Afiliacion[] @relation("AfilArl")
  afiliacionesComoCcf Afiliacion[] @relation("AfilCcf")

  @@unique([tipo, codigo])
  @@index([tipo])
  @@map("entidades_sgss")
}

model ActividadEconomica {
  id          String   @id @default(cuid())
  codigoCiiu  String   @unique
  descripcion String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  empresasPermitidas EmpresaActividad[]
  cargos             Cargo[]
  afiliaciones       Afiliacion[]

  @@map("actividades_economicas")
}

// Régimen aplicable a un Plan SGSS. Si es AMBOS, el plan puede usarse
// con cotizantes de cualquier régimen; si se restringe a ORDINARIO o
// RESOLUCION, la UI de afiliación solo permite elegirlo cuando coincide.
enum RegimenPlan {
  ORDINARIO
  RESOLUCION
  AMBOS
}

// Plan SGSS — combinación de entidades que un cotizante puede tener
// en una afiliación (p.ej. "EPS + ARL", "EPS + AFP + ARL"). El plan
// determina qué campos de entidades son requeridos/visibles en el form.
model PlanSgss {
  id          String   @id @default(cuid())
  codigo      String   @unique
  nombre      String
  descripcion String?
  incluyeEps  Boolean  @default(false)
  incluyeAfp  Boolean  @default(false)
  incluyeArl  Boolean  @default(false)
  incluyeCcf  Boolean  @default(false)
  regimen     RegimenPlan @default(AMBOS)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  afiliaciones Afiliacion[]

  @@index([regimen])
  @@map("planes_sgss")
}

// Formato del comprobante de pago — uno por sucursal (aliado).
// Personaliza logo, encabezado, pie de página y (futuro) campos JSON.
model ComprobanteFormato {
  id           String   @id @default(cuid())
  sucursalId   String   @unique
  nombre       String   @default("Predeterminado")
  logoUrl      String?
  encabezado   String?
  pieDePagina  String?
  camposConfig Json?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sucursal Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  @@map("comprobante_formatos")
}

// Cuenta de Cobro (Empresa Empleadora) — agrupador de cotizantes para
// facturación masiva. Scoped por sucursal (cada aliado mantiene las suyas).
model CuentaCobro {
  id                String         @id @default(cuid())
  sucursalId        String
  codigo            String
  razonSocial       String
  nit               String?
  dv                String?
  tipoPersona       TipoPersona?
  repLegalTipoDoc   TipoDocumento?
  repLegalNumeroDoc String?
  repLegalNombre    String?
  direccion         String?
  ciudad            String?
  departamento      String?
  telefono          String?
  email             String?
  active            Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  sucursal     Sucursal      @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  afiliaciones Afiliacion[]
  comprobantes Comprobante[]

  @@unique([sucursalId, codigo])
  @@index([sucursalId])
  @@map("cuentas_cobro")
}

// Cargo ocupacional — ligado a una actividad económica
model Cargo {
  id                   String   @id @default(cuid())
  codigo               String   @unique
  nombre               String
  actividadEconomicaId String?
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  actividad ActividadEconomica? @relation(fields: [actividadEconomicaId], references: [id], onDelete: SetNull)

  @@index([actividadEconomicaId])
  @@map("cargos")
}

// Asesor comercial — se ancla a cotizante para reportería/comisiones
// Asesor comercial — scoped por sucursal (cada aliado tiene los suyos).
// sucursalId null = recurso "global" visible por todas las sucursales
// (caso excepcional, gestionado por ADMIN/SOPORTE).
model AsesorComercial {
  id         String   @id @default(cuid())
  sucursalId String?
  codigo     String
  nombre     String
  email      String?
  telefono   String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sucursal     Sucursal?     @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  afiliaciones Afiliacion[]
  comprobantes Comprobante[]

  @@unique([sucursalId, codigo])
  @@index([sucursalId])
  @@map("asesores_comerciales")
}

// Medio de pago — scoped por sucursal
model MedioPago {
  id         String   @id @default(cuid())
  sucursalId String?
  codigo     String
  nombre     String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sucursal     Sucursal?    @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  comprobantes Comprobante[]

  @@unique([sucursalId, codigo])
  @@index([sucursalId])
  @@map("medios_pago")
}

// Servicio adicional — scoped por sucursal (cada aliado puede tener sus
// propios planes/servicios extra).
model ServicioAdicional {
  id          String   @id @default(cuid())
  sucursalId  String?
  codigo      String
  nombre      String
  descripcion String?
  precio      Decimal  @default(0) @db.Decimal(12, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sucursal     Sucursal?            @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  afiliaciones AfiliacionServicio[]

  @@unique([sucursalId, codigo])
  @@index([sucursalId])
  @@map("servicios_adicionales")
}

model TipoCotizante {
  id        String    @id @default(cuid())
  codigo    String    @unique
  nombre    String
  modalidad Modalidad @default(DEPENDIENTE)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  subtipos           Subtipo[]
  empresasPermitidas EmpresaTipoCotizante[]
  afiliaciones       Afiliacion[]

  @@map("tipos_cotizante")
}

model Subtipo {
  id              String   @id @default(cuid())
  codigo          String
  nombre          String
  tipoCotizanteId String
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tipoCotizante      TipoCotizante             @relation(fields: [tipoCotizanteId], references: [id], onDelete: Cascade)
  empresasPermitidas EmpresaSubtipoCotizante[]
  afiliaciones       Afiliacion[]

  @@unique([codigo, tipoCotizanteId])
  @@index([tipoCotizanteId])
  @@map("subtipos_cotizante")
}

// --- Cotizante (cliente afiliado) y Afiliación (Fase 2.1) ---

model Cotizante {
  id                 String        @id @default(cuid())
  /**
   * Sucursal dueña del registro (multi-tenant). Cada sucursal maneja sus
   * propios cotizantes — la misma persona puede existir como dos registros
   * en sucursales distintas. sucursalId=null se reserva para cotizantes
   * legados sin asignar (staff los puede migrar desde la UI).
   */
  sucursalId         String?
  tipoDocumento      TipoDocumento
  numeroDocumento    String
  fechaExpedicionDoc DateTime?
  primerNombre       String
  segundoNombre      String?
  primerApellido     String
  segundoApellido    String?
  fechaNacimiento    DateTime
  genero             Genero
  telefono           String?
  celular            String?
  email              String?
  direccion          String?
  municipioId        String?
  departamentoId     String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  sucursal     Sucursal?        @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  afiliaciones Afiliacion[]
  comprobantes Comprobante[]
  gestionesCartera GestionCartera[]
  planillas    Planilla[]
  carterasDetallado CarteraDetallado[]
  municipio    Municipio?    @relation(fields: [municipioId], references: [id], onDelete: SetNull)
  departamento Departamento? @relation(fields: [departamentoId], references: [id], onDelete: SetNull)

  @@unique([sucursalId, tipoDocumento, numeroDocumento])
  @@index([sucursalId])
  @@index([primerApellido, primerNombre])
  @@index([municipioId])
  @@index([departamentoId])
  @@map("cotizantes")
}

// Afiliación — liga un cotizante a una empresa con su plan (tipo/subtipo/nivel/salario).
// Para INDEPENDIENTE, empresaId y regimen no aplican y arlId se elige directamente.
model Afiliacion {
  id                   String           @id @default(cuid())
  cotizanteId          String
  empresaId            String?
  cuentaCobroId        String?
  asesorComercialId    String?
  planSgssId           String?
  actividadEconomicaId String?
  tipoCotizanteId      String
  subtipoId            String?
  modalidad            Modalidad        @default(DEPENDIENTE)
  nivelRiesgo          NivelRiesgo
  regimen              Regimen?
  formaPago            FormaPago? // sólo INDEPENDIENTE
  salario              Decimal          @db.Decimal(12, 2)
  valorAdministracion  Decimal          @db.Decimal(12, 2)
  fechaIngreso         DateTime
  fechaRetiro          DateTime?
  estado               EstadoAfiliacion @default(ACTIVA)
  comentarios          String?

  // Entidades SGSS asignadas (EntidadSgss filtrada por tipo)
  epsId String?
  afpId String?
  arlId String? // solo para INDEPENDIENTE — el dependiente hereda la ARL de la empresa
  ccfId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cotizante          Cotizante           @relation(fields: [cotizanteId], references: [id], onDelete: Cascade)
  empresa            Empresa?            @relation(fields: [empresaId], references: [id], onDelete: Restrict)
  cuentaCobro        CuentaCobro?        @relation(fields: [cuentaCobroId], references: [id], onDelete: SetNull)
  asesorComercial    AsesorComercial?    @relation(fields: [asesorComercialId], references: [id], onDelete: SetNull)
  planSgss           PlanSgss?           @relation(fields: [planSgssId], references: [id], onDelete: SetNull)
  actividadEconomica ActividadEconomica? @relation(fields: [actividadEconomicaId], references: [id], onDelete: SetNull)
  tipoCotizante      TipoCotizante       @relation(fields: [tipoCotizanteId], references: [id], onDelete: Restrict)
  subtipo            Subtipo?            @relation(fields: [subtipoId], references: [id], onDelete: SetNull)
  eps                EntidadSgss?        @relation("AfilEps", fields: [epsId], references: [id], onDelete: SetNull)
  afp                EntidadSgss?        @relation("AfilAfp", fields: [afpId], references: [id], onDelete: SetNull)
  arl                EntidadSgss?        @relation("AfilArl", fields: [arlId], references: [id], onDelete: SetNull)
  ccf                EntidadSgss?        @relation("AfilCcf", fields: [ccfId], references: [id], onDelete: SetNull)

  serviciosAdicionales AfiliacionServicio[]
  liquidaciones        Liquidacion[]

  @@index([cotizanteId])
  @@index([empresaId])
  @@index([estado])
  @@index([modalidad])
  @@index([actividadEconomicaId])
  @@index([arlId])
  @@map("afiliaciones")
}

// Servicios adicionales asignados a una afiliación (many-to-many)
model AfiliacionServicio {
  afiliacionId        String
  servicioAdicionalId String
  createdAt           DateTime @default(now())

  afiliacion Afiliacion        @relation(fields: [afiliacionId], references: [id], onDelete: Cascade)
  servicio   ServicioAdicional @relation(fields: [servicioAdicionalId], references: [id], onDelete: Cascade)

  @@id([afiliacionId, servicioAdicionalId])
  @@map("afiliacion_servicios")
}

// --- Configuración SMLV (singleton) ---
// El admin actualiza el valor; al guardar se cascadea a todas las
// afiliaciones con salario < valor nuevo.
model SmlvConfig {
  id           String   @id @default("singleton")
  valor        Decimal  @db.Decimal(12, 2)
  vigenteDesde DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("smlv_config")
}

// --- Tarifas SGSS (Fase 2.8) ---
// Catálogo de porcentajes por concepto (EPS/AFP/ARL/CCF/SENA/ICBF) con
// discriminadores por modalidad, nivel ARL y exoneración (Ley 1607).
// Una fila representa un porcentaje aplicable en una combinación. El
// motor de liquidación consulta este catálogo para armar la planilla.
//
// `concepto` es string plano (no enum) para poder añadir conceptos
// nuevos sin migración (ej. FIC, AFC, etc. en el futuro).
model TarifaSgss {
  id            String       @id @default(cuid())
  concepto      String // EPS | AFP | ARL | CCF | SENA | ICBF
  modalidad     Modalidad? // NULL = aplica a ambas (AFP, ARL)
  nivelRiesgo   NivelRiesgo? // sólo ARL
  exonera       Boolean? // NULL = no aplica (ARL/AFP); true/false para EPS/SENA/ICBF en DEPENDIENTE
  porcentaje    Decimal      @db.Decimal(6, 4) // ej 12.5000 = 12.5%
  etiqueta      String? // nombre corto mostrado en UI (p. ej. "CCF Independiente 2%")
  observaciones String?
  active        Boolean      @default(true)
  vigenteDesde  DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([concepto])
  @@index([active])
  @@map("tarifas_sgss")
}

// --- Transacciones / Liquidación (Fase 3.0) ---

enum EstadoPeriodo {
  ABIERTO // se pueden liquidar/editar afiliaciones
  CERRADO // snapshot final; no se permite recalcular
}

enum EstadoLiquidacion {
  BORRADOR // recién calculada por el motor
  REVISADA // admin la revisó y aprobó
  PAGADA // con pago aplicado
  ANULADA
}

// Tipo de liquidación dentro de un período:
// VINCULACION = primer comprobante del afiliado, días proporcionales
//               desde fecha de ingreso al día 30 PILA
// MENSUALIDAD = mes completo (30 días PILA)
enum TipoLiquidacion {
  VINCULACION
  MENSUALIDAD
}

// Comprobantes — agrupadores de liquidaciones con consecutivo propio.
enum TipoComprobante {
  AFILIACION // primer comprobante del cotizante (engloba las VINCULACION)
  MENSUALIDAD // comprobante regular del mes
}

enum AgrupacionComprobante {
  INDIVIDUAL // 1 cotizante
  EMPRESA_CC // todos los cotizantes de una cuenta de cobro
  ASESOR_COMERCIAL // todos los cotizantes de un asesor (reporte / comisión)
}

enum EstadoComprobante {
  BORRADOR // recién generado
  EMITIDO // firmado/impreso
  PAGADO
  ANULADO
}

// Forma de pago al procesar una transacción.
// POR_CONFIGURACION = toma la forma de pago configurada (ej. Nequi/Bancolombia)
// CONSOLIDADO       = pago consolidado (múltiples liquidaciones agrupadas)
// POR_MEDIO_PAGO    = se referencia un MedioPago específico del catálogo
enum FormaPagoTransaccion {
  POR_CONFIGURACION
  CONSOLIDADO
  POR_MEDIO_PAGO
}

// Período contable mensual — uno por (año, mes). El admin abre el período,
// corre la liquidación, revisa y eventualmente cierra. SMLV y tarifas
// vigentes al momento de abrir quedan denormalizadas en cada liquidación.
model PeriodoContable {
  id           String        @id @default(cuid())
  anio         Int
  mes          Int // 1..12
  estado       EstadoPeriodo @default(ABIERTO)
  smlvSnapshot Decimal       @db.Decimal(12, 2) // SMLV vigente al abrir
  observaciones String?
  abiertoEn    DateTime      @default(now())
  cerradoEn    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  liquidaciones Liquidacion[]
  comprobantes  Comprobante[]
  gestionesCartera GestionCartera[]
  planillas     Planilla[]

  @@unique([anio, mes])
  @@index([estado])
  @@map("periodos_contables")
}

// Liquidación — una por (periodo × afiliación). El motor genera el
// desglose en `LiquidacionConcepto`. El `ibc` es la base de cotización
// del período (puede ser distinta al salario por novedades futuras).
model Liquidacion {
  id              String            @id @default(cuid())
  periodoId       String
  afiliacionId    String
  tipo            TipoLiquidacion   @default(MENSUALIDAD)
  ibc             Decimal           @db.Decimal(12, 2)
  // Período al que corresponde el APORTE SGSS (clave para el plano PILA).
  // Puede diferir del `periodoId` cuando es un independiente con forma
  // de pago VENCIDO: se factura en el mes siguiente pero cotiza por el
  // mes anterior. NULL → mismo mes que el período contable.
  periodoAporteAnio Int?
  periodoAporteMes  Int?
  diasCotizados   Int               @default(30) // sobre mes PILA de 30 días
  diaDesde        Int? // día (1..30) de inicio del periodo cotizado; NULL = mes completo
  diaHasta        Int? // día (1..30) de fin del periodo cotizado; NULL = mes completo
  totalEmpleador  Decimal           @db.Decimal(14, 2) @default(0)
  totalTrabajador Decimal           @db.Decimal(14, 2) @default(0)
  totalGeneral    Decimal           @db.Decimal(14, 2) @default(0)
  totalPagado     Decimal           @db.Decimal(14, 2) @default(0)
  estado          EstadoLiquidacion @default(BORRADOR)
  observaciones   String?
  calculadoEn     DateTime          @default(now())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  periodo      PeriodoContable          @relation(fields: [periodoId], references: [id], onDelete: Cascade)
  afiliacion   Afiliacion               @relation(fields: [afiliacionId], references: [id], onDelete: Cascade)
  conceptos    LiquidacionConcepto[]
  comprobantes ComprobanteLiquidacion[]

  @@unique([periodoId, afiliacionId, tipo])
  @@index([periodoId])
  @@index([afiliacionId])
  @@index([estado])
  @@index([tipo])
  @@map("liquidaciones")
}

// Desglose línea-por-concepto de una liquidación. Se recrea en cada
// recálculo (deleteMany + createMany dentro de transacción).
// `aCargoEmpleador` indica si el valor pesa sobre el empleador (para
// dependientes) o sobre el trabajador/aportante.
model LiquidacionConcepto {
  id               String   @id @default(cuid())
  liquidacionId    String
  concepto         String // EPS | AFP | ARL | CCF | SENA | ICBF | FSP | ADMIN
  subconcepto      String? // ej. "EPS-empleador 8.5%" vs "EPS-trabajador 4%"
  base             Decimal  @db.Decimal(12, 2)
  // Decimal(8,4) para soportar hasta 9999.9999. El concepto ADMIN usa
  // 100.0000 ya que no es realmente un porcentaje sino un valor fijo.
  porcentaje       Decimal  @db.Decimal(8, 4)
  valor            Decimal  @db.Decimal(14, 2)
  aCargoEmpleador  Boolean  @default(true)
  observaciones    String?
  createdAt        DateTime @default(now())

  liquidacion Liquidacion @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)

  @@index([liquidacionId])
  @@index([concepto])
  @@map("liquidacion_conceptos")
}

// FSP — Fondo de Solidaridad Pensional. Tabla por rangos de SMLV del
// ingreso base de cotización. smlvHasta NULL = rango sin tope superior.
model FspRango {
  id           String   @id @default(cuid())
  smlvDesde    Decimal  @db.Decimal(6, 2)
  smlvHasta    Decimal? @db.Decimal(6, 2)
  porcentaje   Decimal  @db.Decimal(6, 4)
  active       Boolean  @default(true)
  vigenteDesde DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active])
  @@map("fsp_rangos")
}

// --- Departamentos y municipios de Colombia (DIVIPOLA) ---
model Departamento {
  id     String @id @default(cuid())
  codigo String @unique // DIVIPOLA 2 dígitos
  nombre String @unique

  municipios Municipio[]
  cotizantes Cotizante[]
  empresas   Empresa[]   @relation("EmpresaDepto")

  @@map("departamentos")
}

model Municipio {
  id             String @id @default(cuid())
  codigo         String @unique // DIVIPOLA 5 dígitos
  nombre         String
  departamentoId String

  departamento Departamento @relation(fields: [departamentoId], references: [id], onDelete: Cascade)
  cotizantes   Cotizante[]
  empresas     Empresa[]    @relation("EmpresaMuni")

  @@unique([nombre, departamentoId])
  @@index([departamentoId])
  @@map("municipios")
}

// --- Comprobantes (Fase 3.2) ---
// Un comprobante agrupa 1..N liquidaciones y se emite al destinatario
// (cotizante, cuenta de cobro o asesor) con un consecutivo propio.
model Comprobante {
  id                String                @id @default(cuid())
  periodoId         String
  tipo              TipoComprobante
  agrupacion        AgrupacionComprobante
  consecutivo       String                @unique // CMP-000001
  // Destinatario: según `agrupacion`, uno de estos está poblado
  cotizanteId       String?
  cuentaCobroId     String?
  asesorComercialId String?
  // Totales denormalizados — se desglosan para facturación y reporte.
  // totalGeneral = totalSgss + totalAdmon + totalServicios
  totalSgss       Decimal           @db.Decimal(14, 2) @default(0)
  totalAdmon      Decimal           @db.Decimal(14, 2) @default(0)
  totalServicios  Decimal           @db.Decimal(14, 2) @default(0)
  totalEmpleador  Decimal           @db.Decimal(14, 2) @default(0) // (legado — no se muestra en UI)
  totalTrabajador Decimal           @db.Decimal(14, 2) @default(0) // (legado — no se muestra en UI)
  totalGeneral    Decimal           @db.Decimal(14, 2) @default(0)
  totalPagado     Decimal           @db.Decimal(14, 2) @default(0)
  estado          EstadoComprobante @default(BORRADOR)
  observaciones   String?

  // Pre-facturación y procesamiento
  numeroComprobanteExt String? // número impreso / externo ingresado por el admin
  formaPago            FormaPagoTransaccion?
  fechaPago            DateTime?
  medioPagoId          String?
  procesadoEn          DateTime? // timestamp del click "Procesar"
  emitidoEn            DateTime?
  pagadoEn             DateTime?

  // Override de valor administración en la pre-factura (afecta sólo la
  // transacción, no el valor guardado en la afiliación). Si es NULL, se
  // usó el valor default de la afiliación.
  valorAdminOverride  Decimal? @db.Decimal(12, 2)

  // Marca que al procesar esta factura se inactivó al cotizante (novedad
  // de retiro). Al anular se reactiva.
  aplicaNovedadRetiro Boolean  @default(false)

  // Marca que esta factura se creó durante el cierre masivo del período.
  // Al anularse, el período se reabre automáticamente.
  esCierreMasivo      Boolean  @default(false)

  // Número de planilla PILA asignado cuando se procesa en el módulo de
  // Planos. Mientras NULL, la transacción se muestra "En proceso".
  numeroPlanilla      String?

  // Usuario que creó (procesó) el comprobante. SetNull si el usuario
  // se elimina para no perder el registro.
  createdById         String?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  periodo         PeriodoContable          @relation(fields: [periodoId], references: [id], onDelete: Cascade)
  cotizante       Cotizante?               @relation(fields: [cotizanteId], references: [id], onDelete: Restrict)
  cuentaCobro     CuentaCobro?             @relation(fields: [cuentaCobroId], references: [id], onDelete: Restrict)
  asesorComercial AsesorComercial?         @relation(fields: [asesorComercialId], references: [id], onDelete: Restrict)
  medioPago       MedioPago?               @relation(fields: [medioPagoId], references: [id], onDelete: SetNull)
  createdBy       User?                    @relation("ComprobantesCreados", fields: [createdById], references: [id], onDelete: SetNull)
  liquidaciones   ComprobanteLiquidacion[]
  planillas       PlanillaComprobante[]

  @@index([periodoId])
  @@index([estado])
  @@index([tipo, agrupacion])
  @@index([cotizanteId])
  @@index([cuentaCobroId])
  @@index([asesorComercialId])
  @@index([medioPagoId])
  @@index([procesadoEn])
  @@index([numeroPlanilla])
  @@index([createdById])
  @@map("comprobantes")
}

// Bitácora de gestión de cartera — registra las acciones del admin
// para cobrar a un cotizante en un período (llamadas, emails, notas).
model GestionCartera {
  id          String   @id @default(cuid())
  cotizanteId String
  periodoId   String
  accion      String // LLAMADA | EMAIL | SMS | VISITA | NOTA | OTRO
  descripcion String
  userId      String?
  userName    String?
  createdAt   DateTime @default(now())

  cotizante Cotizante       @relation(fields: [cotizanteId], references: [id], onDelete: Cascade)
  periodo   PeriodoContable @relation(fields: [periodoId], references: [id], onDelete: Cascade)

  @@index([cotizanteId])
  @@index([periodoId])
  @@index([cotizanteId, periodoId])
  @@map("gestiones_cartera")
}

// Pivote m2m. Una liquidación puede estar en varios comprobantes (p.ej.
// el de cobro por CC + el informativo del asesor), por eso NO hay
// unique sobre liquidacionId.
model ComprobanteLiquidacion {
  comprobanteId String
  liquidacionId String

  comprobante Comprobante @relation(fields: [comprobanteId], references: [id], onDelete: Cascade)
  liquidacion Liquidacion @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)

  @@id([comprobanteId, liquidacionId])
  @@index([liquidacionId])
  @@map("comprobante_liquidaciones")
}

// --- Planos PILA (Fase P1) ---

// Tipo de planilla según resolución 2388/2016 (campo 8 del encabezado).
// Arrancamos con E (empleados) e I (independientes); ampliar a N/Y/K/otros
// según aparezcan casos.
enum TipoPlanilla {
  E // Planilla empleados (dependientes)
  I // Planilla independientes
  Y // Planilla independientes empresa (cooperativas, asociados)
  N // Planilla correcciones
  K // Planilla estudiantes
  A // Planilla cotizantes con novedad de ingreso
  S // Planilla empleados servicio doméstico
}

enum EstadoPlanilla {
  CONSOLIDADO // Recién creada, pendiente de pago
  PAGADA      // Pago confirmado — se guarda numeroPlanillaExt y fecha
  ANULADA     // Al anular se libera el vínculo con los comprobantes
}

// Planilla PILA — un registro agrupa los comprobantes de UN aportante
// (empresa para dependientes / cotizante para independientes) en un
// período de aporte. Un aportante puede tener varias planillas si hay
// desfase por independiente vencido u otro caso.
model Planilla {
  id                 String         @id @default(cuid())
  periodoId          String
  /**
   * Sucursal que genera la planilla (multi-tenant). Cuando una empresa
   * planilla global tiene cotizantes de múltiples aliados, se genera una
   * planilla tipo E por sucursal. Para planillas tipo I, coincide con
   * `cotizante.sucursalId`.
   */
  sucursalId         String?
  consecutivo        String         @unique // PLN-000001 (sequence Postgres)
  tipoPlanilla       TipoPlanilla
  // Nro. de planilla asignado por el operador PILA al confirmar el pago
  numeroPlanillaExt  String?
  // Aportante: exactamente UNO de estos está poblado según tipoPlanilla
  empresaId          String?        // NOT NULL si tipo = E (dependientes)
  cotizanteId        String?        // NOT NULL si tipo = I/Y (independiente)
  // Período de APORTE (puede diferir del contable para indep vencido)
  periodoAporteAnio  Int
  periodoAporteMes   Int
  // Totales snapshot por subsistema
  totalSalud         Decimal        @db.Decimal(14, 2) @default(0)
  totalPension       Decimal        @db.Decimal(14, 2) @default(0)
  totalArl           Decimal        @db.Decimal(14, 2) @default(0)
  totalCcf           Decimal        @db.Decimal(14, 2) @default(0)
  totalSena          Decimal        @db.Decimal(14, 2) @default(0)
  totalIcbf          Decimal        @db.Decimal(14, 2) @default(0)
  totalFsp           Decimal        @db.Decimal(14, 2) @default(0)
  totalGeneral       Decimal        @db.Decimal(14, 2) @default(0)
  cantidadCotizantes Int            @default(0)
  estado             EstadoPlanilla @default(CONSOLIDADO)
  generadoEn         DateTime       @default(now())
  pagadoEn           DateTime?
  createdById        String?
  observaciones      String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  periodo      PeriodoContable       @relation(fields: [periodoId], references: [id], onDelete: Restrict)
  sucursal     Sucursal?             @relation(fields: [sucursalId], references: [id], onDelete: Restrict)
  empresa      Empresa?              @relation(fields: [empresaId], references: [id], onDelete: Restrict)
  cotizante    Cotizante?            @relation(fields: [cotizanteId], references: [id], onDelete: Restrict)
  createdBy    User?                 @relation("PlanillasCreadas", fields: [createdById], references: [id], onDelete: SetNull)
  comprobantes PlanillaComprobante[]

  @@index([periodoId])
  @@index([sucursalId])
  @@index([estado])
  @@index([tipoPlanilla])
  @@index([empresaId])
  @@index([cotizanteId])
  @@index([periodoAporteAnio, periodoAporteMes])
  @@map("planillas")
}

// Pivote Planilla ↔ Comprobante. Un comprobante puede estar en varias
// planillas (p.ej. una afiliación de RESOLUCIÓN con plan EPS+ARL genera
// dos planillas — tipo E y tipo K — que referencian al mismo comprobante).
// La PK compuesta @@id evita duplicados dentro de la misma planilla.
// Al anular la planilla se borran estas filas (cascade).
model PlanillaComprobante {
  planillaId    String
  comprobanteId String
  createdAt     DateTime @default(now())

  planilla    Planilla    @relation(fields: [planillaId], references: [id], onDelete: Cascade)
  comprobante Comprobante @relation(fields: [comprobanteId], references: [id], onDelete: Restrict)

  @@id([planillaId, comprobanteId])
  @@index([comprobanteId])
  @@map("planillas_comprobantes")
}

// ============================================================
// MÓDULO CARTERA (Soporte + Administrativo)
// ============================================================
// Estados de cuenta importados desde las entidades SGSS (EPS/AFP/ARL/CCF)
// vía PDF. El módulo Soporte los carga y los pasa a "CARTERA_REAL" cuando
// confirma que la deuda es válida; a partir de ese estado aparecen en el
// módulo Administrativo del aliado dueño de la sucursal asignada.

/** Tipo de entidad SGSS emisora del estado de cuenta. */
enum CarteraTipoEntidad {
  EPS
  AFP
  ARL
  CCF
}

/**
 * Estado del detallado (por línea) y también del consolidado.
 *
 *   - EN_CONCILIACION      recién importado; soporte lo revisa
 *   - CONCILIADA           soporte respondió a la entidad / descartó la deuda
 *   - CARTERA_REAL         soporte confirmó: es deuda real → aparece en el aliado
 *   - PAGADA_CARTERA_REAL  el aliado pagó la cartera real confirmada
 */
enum CarteraEstado {
  EN_CONCILIACION
  CONCILIADA
  CARTERA_REAL
  PAGADA_CARTERA_REAL
}

/** Origen del PDF — detectado por el parser; MANUAL = el staff lo mapeó a mano. */
enum CarteraOrigenPdf {
  PROTECCION
  SALUD_TOTAL
  EPS_SOS
  EPS_SURA
  EPS_SANITAS
  MANUAL
}

/** Quién registró la gestión: staff de soporte o el aliado dueño de la sucursal. */
enum CarteraAccionadaPor {
  SOPORTE
  ALIADO
}

/**
 * Cabecera del estado de cuenta importado. Un consolidado agrupa todas
 * las líneas (CarteraDetallado) de un mismo PDF: la entidad emisora, la
 * empresa afectada y el período de corte.
 *
 * La unique `(empresaNit, entidadNombre, periodoHasta)` bloquea re-imports
 * silenciosos: si el staff sube dos veces el mismo estado de cuenta, el
 * action exige confirmación explícita para reemplazar.
 */
model CarteraConsolidado {
  id                  String             @id @default(cuid())
  consecutivo         String             @unique              // CC-000001 (sequence Postgres)
  fechaRegistro       DateTime           @default(now())
  tipoEntidad         CarteraTipoEntidad
  entidadNombre       String                                   // "Salud Total EPS"
  entidadNit          String?                                  // NIT de la entidad (si el PDF lo trae)
  empresaNit          String                                   // NIT empleador reportado en el PDF
  empresaRazonSocial  String                                   // razón social del PDF (denormalizada)
  empresaId           String?                                  // match con Empresa en BD (si existe)
  periodoDesde        String?                                  // "AAAA-MM" — inicio de la ventana reportada
  periodoHasta        String?                                  // "AAAA-MM" — corte del estado de cuenta
  cantidadRegistros   Int                @default(0)
  valorTotalInformado Decimal            @db.Decimal(15, 2)
  estado              CarteraEstado      @default(EN_CONCILIACION)
  origenPdf           CarteraOrigenPdf?
  archivoOrigenPath   String?                                  // ruta relativa al PDF archivado
  archivoOrigenHash   String?                                  // sha-256 para trazabilidad
  observaciones       String?
  createdById         String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  empresa   Empresa?           @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  createdBy User?              @relation("CarterasCreadas", fields: [createdById], references: [id], onDelete: SetNull)
  detallado CarteraDetallado[]

  @@unique([empresaNit, entidadNombre, periodoHasta])
  @@index([empresaId])
  @@index([estado])
  @@index([fechaRegistro])
  @@map("cartera_consolidado")
}

/**
 * Una línea del estado de cuenta = un cotizante + un período + un valor.
 * El estado es por línea (no solo por consolidado) — solo las líneas
 * marcadas CARTERA_REAL aparecen en el módulo Administrativo del aliado.
 *
 * `sucursalAsignadaId` se auto-matchea por cédula contra la BD; queda
 * editable para que soporte la reasigne si el auto-match falla.
 */
model CarteraDetallado {
  id                 String        @id @default(cuid())
  consolidadoId      String
  tipoDocumento      TipoDocumento
  numeroDocumento    String
  nombreCompleto     String
  periodoCobro       String                                   // "AAAA-MM"
  valorCobro         Decimal       @db.Decimal(15, 2)
  ibc                Decimal?      @db.Decimal(15, 2)         // IBC reportado (solo algunos formatos)
  novedad            String?                                   // IGE, NVL, etc. (texto libre)
  sucursalAsignadaId String?
  cotizanteId        String?                                   // match con Cotizante en BD (opcional)
  estado             CarteraEstado @default(EN_CONCILIACION)
  observaciones      String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  consolidado      CarteraConsolidado @relation(fields: [consolidadoId], references: [id], onDelete: Cascade)
  sucursalAsignada Sucursal?          @relation(fields: [sucursalAsignadaId], references: [id], onDelete: SetNull)
  cotizante        Cotizante?         @relation(fields: [cotizanteId], references: [id], onDelete: SetNull)
  gestiones        CarteraGestion[]

  @@index([consolidadoId])
  @@index([sucursalAsignadaId])
  @@index([cotizanteId])
  @@index([estado])
  @@index([numeroDocumento])
  @@map("cartera_detallado")
}

/**
 * Bitácora de gestiones sobre una línea. Soporte y el aliado registran
 * sus acciones aquí; el enum `accionadaPor` distingue de qué lado viene.
 * Si la gestión cambia de estado, `nuevoEstado` lo captura para auditoría.
 */
model CarteraGestion {
  id           String              @id @default(cuid())
  detalladoId  String
  accionadaPor CarteraAccionadaPor
  nuevoEstado  CarteraEstado?                               // si la gestión promovió el estado
  descripcion  String
  userId       String?
  userName     String?
  createdAt    DateTime            @default(now())

  detallado CarteraDetallado @relation(fields: [detalladoId], references: [id], onDelete: Cascade)
  user      User?            @relation("CarterasGestionesUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([detalladoId])
  @@index([userId])
