# =============================================================================
#  Sistema PILA — variables de entorno
# =============================================================================
# Copia este archivo a `.env` y completá los valores. Las marcadas con [DEV] son
# opcionales en local; las [PROD] son obligatorias para deploy a producción.

# -----------------------------------------------------------------------------
# Base de datos (Postgres) — [PROD] obligatorio
# -----------------------------------------------------------------------------
# En desarrollo apuntamos a la BD dev de Neon. En producción usá una conexión
# con pooling (la URL termina en `-pooler.us-east-1.aws.neon.tech`).
DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public&sslmode=require"

# -----------------------------------------------------------------------------
# NextAuth v5 (Auth.js) — [PROD] obligatorio
# -----------------------------------------------------------------------------
# AUTH_SECRET: generar con
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="cambiar-en-produccion-minimo-32-bytes-base64"
# AUTH_URL es la URL pública del sitio (incluí https en prod).
AUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# PagoSimple — integración API PILA — [PROD] obligatorio si se usa
# -----------------------------------------------------------------------------
# Si todas estas vars están vacías, el módulo PagoSimple queda deshabilitado y
# las planillas no se pueden subir al operador.
PAGOSIMPLE_BASE_URL="https://api.pagosimple.com"
# Aportante MASTER (la empresa operadora que se autentica contra PagoSimple).
PAGOSIMPLE_MASTER_NIT=""
PAGOSIMPLE_MASTER_COMPANY=""
PAGOSIMPLE_MASTER_SECRET_KEY=""
PAGOSIMPLE_MASTER_DOCUMENT_TYPE="CC"
PAGOSIMPLE_MASTER_DOCUMENT=""
PAGOSIMPLE_MASTER_PASSWORD=""
# TTL del token cacheado (defaults a 15 min). Subilo si se está renovando con
# demasiada frecuencia y bajalo si PagoSimple invalida tokens antes.
PAGOSIMPLE_TOKEN_TTL_MIN="15"

# -----------------------------------------------------------------------------
# Almacenamiento de archivos subidos — [PROD] obligatorio
# -----------------------------------------------------------------------------
# Carpeta raíz donde se guardan adjuntos (incapacidades, cartera PDF, etc.).
# En producción apuntá a un volumen persistente (Vercel Blob, S3 montado, etc.).
UPLOADS_DIR="./uploads"

# -----------------------------------------------------------------------------
# Logging — [DEV] opcional
# -----------------------------------------------------------------------------
# Niveles válidos: trace | debug | info | warn | error | fatal | silent
# - dev:  "debug" (más verbose) o "info"
# - prod: "info" o "warn"
LOG_LEVEL="info"

# -----------------------------------------------------------------------------
# Sentry (monitoreo de errores) — [PROD] opcional pero recomendado
# -----------------------------------------------------------------------------
# Si SENTRY_DSN está vacío, el SDK queda en modo no-op (no se mandan eventos
# y no hay overhead). En producción, conseguir un DSN desde sentry.io →
# Settings → Projects → tu proyecto → Client Keys (DSN).
SENTRY_DSN=""

# -----------------------------------------------------------------------------
# Entorno — [DEV] opcional
# -----------------------------------------------------------------------------
NODE_ENV="development"

# -----------------------------------------------------------------------------
# Backup automatizado a S3 (opcional pero recomendado en prod) — [PROD]
# -----------------------------------------------------------------------------
# Solo se usa por el GitHub Action `db-backup.yml`. Si no se configuran, el
# workflow falla con un mensaje claro y queda fuera el backup automatizado.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
BACKUP_S3_BUCKET=""
# Prefijo dentro del bucket: ej. "pila-prod" → s3://bucket/pila-prod/2026-04-25.dump
BACKUP_S3_PREFIX="pila-prod"

# -----------------------------------------------------------------------------
# Legacy — Google APIs (Sheets, Drive, Gmail), no usado activamente
# -----------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_KEY=""
DRIVE_ROOT_FOLDER_ID=""
DRIVE_SOPORTES_FOLDER_ID=""

# -----------------------------------------------------------------------------
# Legacy — Portal Colpatria (bot ARL), no usado activamente
# -----------------------------------------------------------------------------
COLPATRIA_BASE_URL=""
COLPATRIA_HEADLESS="true"
