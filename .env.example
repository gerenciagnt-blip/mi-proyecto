# --- Base de datos ---
DATABASE_URL="postgresql://pila:pila@localhost:5432/pila_dev?schema=public"

# --- NextAuth v5 (Auth.js) ---
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="cambiar-en-produccion-minimo-32-bytes-base64"
AUTH_URL="http://localhost:3000"

# --- Google APIs (Sheets, Drive, Gmail) ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_KEY=""

# --- Drive: carpeta raíz para soportes (reemplaza IDs hardcoded del legacy) ---
DRIVE_ROOT_FOLDER_ID=""
DRIVE_SOPORTES_FOLDER_ID=""

# --- Portal Colpatria (bot ARL) ---
COLPATRIA_BASE_URL=""
COLPATRIA_HEADLESS="true"

# --- Entorno ---
NODE_ENV="development"
LOG_LEVEL="info"
