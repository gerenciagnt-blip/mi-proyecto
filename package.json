{
  "name": "sistema-pila",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema PILA — suite unificada (seguridad social, financiero, radicación)",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @pila/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @pila/db prisma:generate",
    "db:migrate": "pnpm --filter @pila/db prisma:migrate",
    "db:studio": "pnpm --filter @pila/db prisma:studio",
    "cli": "pnpm --filter @pila/cli start"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "prettier": "^3.4.2",
    "@types/node": "^22.10.2",
    "dotenv-cli": "^8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
